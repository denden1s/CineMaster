@startchen

left to right direction

entity User {
  UserID : INTEGER <<key>>
  Login : STRING
  Password : STRING
  FullName {
    FirstName : STRING
    LastName : STRING
    Surname : STRING
  }
  Role : INTEGER
}

entity CinemaSession {
  SessionID : INTEGER <<key>>
  UserID : INTEGER
  FilmID : INTEGER
  CinemaHallID : INTEGER
  ShowingTime : DATE
  SpectatorsCount : INTEGER
}

entity Film {
  FilmID : INTEGER <<key>>
  Name : STRING
  Duration : REAL
  GenreID : INTEGER
  Price : REAL
}

entity Genre {
  GenreID : INTEGER <<key>>
  Name : STRING
}

entity Ticket {
  TicketID : INTEGER <<key>>
  SessionID : INTEGER
  UserID : INTEGER
}

entity CinemaHall {
  CinemaHallID : INTEGER <<key>>
  Name : STRING
  Capacity : INTEGER
  VIPScalingPercent : INTEGER
}

entity Log {
  LogID : INTEGER <<key>>
  UserID : INTEGER
  ActionTime : DATE
  Action : STRING
}

relationship SELL {
}

relationship SHOW {
}

relationship WRITE {
}

relationship LOCATE {
}

relationship REFERS_TO {
}

relationship LEAD {
}

' User sell many tickets
' Tickets can be sold by one user
SELL -1- User
SELL -N- Ticket

' Log was writen by concrete user
' Many users write log
WRITE -1- User
WRITE -N- Log


' Film can be showed on many sessions
' Concrete session show concrete film
SHOW -1- Film
SHOW -N- CinemaSession

' Cinema hall can locate many cinema sessions
' Cinema session locate in concrete hall
LOCATE -1- CinemaHall 
LOCATE -N- CinemaSession

' User lead many cinema sessions
' Cinema sessions can be lead by one user
LEAD -1- User
LEAD -N- CinemaSession

' Concrete genre can have many films
' Film reffers to concrete genre
REFERS_TO -1- Genre
REFERS_TO -N- Film

@endchen
