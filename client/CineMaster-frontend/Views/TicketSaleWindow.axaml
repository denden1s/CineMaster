<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:CineMaster_frontend.Models"
        mc:Ignorable="d"
        x:Class="CineMaster_frontend.Views.TicketSaleWindow"
        Title="Продажа билетов"
        Width="480" Height="280">
  <StackPanel Margin="16" Spacing="10">
    <TextBlock Text="Продажа билетов" FontSize="18" FontWeight="Bold"/>

    <TextBlock Text="Сеанс:"/>
    <ComboBox x:Name="SessionCombo">
      <ComboBox.ItemTemplate>
        <DataTemplate x:DataType="models:SessionOption">
          <TextBlock Text="{Binding DisplayName}"/>
        </DataTemplate>
      </ComboBox.ItemTemplate>
    </ComboBox>

    <StackPanel Orientation="Horizontal" Spacing="10">
      <TextBlock Text="Номер места:" VerticalAlignment="Center"/>
      <TextBox Name="SeatNumber" Width="150"/>
    </StackPanel>


    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button Name="SellButton" Content="Продать" Width="110" Click="SellButton_Click"/>
      <Button Name="SellAndPrintQrButton" Content="Продать+QR" Width="110" Click="SellAndPrintQrButton_Click"/>
    </StackPanel>
    <TextBlock Name="StatusText" TextWrapping="Wrap" Foreground="Green"/>
  </StackPanel>
</Window>
