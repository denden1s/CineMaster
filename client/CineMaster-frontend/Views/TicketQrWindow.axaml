<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="CineMaster_frontend.Views.TicketQrWindow"
        Title="QR код билета" Width="360" Height="520">
  <StackPanel Margin="12" Spacing="10">
    <TextBlock Text="QR код для печати" FontSize="18" FontWeight="Bold"/>
    <Image x:Name="QrImage" Width="300" Height="300" Stretch="Uniform"/>
    <TextBlock x:Name="TicketInfoText" TextWrapping="Wrap" FontSize="14"/>
    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
      <Button Content="Сохранить PNG" Click="SavePng_Click"/>
      <Button Content="Закрыть" Click="Close_Click"/>
    </StackPanel>
  </StackPanel>
</Window>