<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CineMaster_frontend.Views.OtherRoleWindow"
        Title="CineMaster"
        Width="400" Height="200"
        CanResize="False">
  <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="Доступ ограничен" FontSize="18" FontWeight="Bold"/>
    <TextBlock Name="MessageText" TextWrapping="Wrap"/>
    <Button Content="Закрыть" HorizontalAlignment="Right" Width="120" Click="CloseButton_Click"/>
  </StackPanel>
</Window>
