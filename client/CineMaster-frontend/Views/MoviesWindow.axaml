<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CineMaster_frontend.Models"
        x:Class="CineMaster_frontend.Views.MoviesWindow"
        Title="Фильмы — ближайшая неделя"
        Width="700" Height="500">
  <DockPanel>
    <TextBlock Text="Сеансы на ближайшую неделю" FontSize="18" FontWeight="Bold" Margin="10" DockPanel.Dock="Top"/>
    <ScrollViewer>
      <ItemsControl x:Name="SessionsList" Margin="10">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:SessionDisplayItem">
            <Border BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,10" Padding="10">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Image Source="{Binding Image}" Width="120" Height="160" Stretch="UniformToFill"/>
                <StackPanel>
                  <TextBlock Text="{Binding FilmName}" FontSize="16" FontWeight="Bold"/>
                  <TextBlock Text="{Binding ShowingTime, StringFormat='Дата: {0:dd.MM.yyyy HH:mm}'}"/>
                  <TextBlock Text="{Binding HallName, StringFormat='Зал: {0}'}"/>
                  <TextBlock Text="{Binding SoldSeats, StringFormat='Продано: {0}'}"/>
                  <TextBlock Text="{Binding RemainingSeats, StringFormat='Осталось: {0}'}"/>
                  <Button Content="Выбрать место" Width="140" Margin="0,8,0,0" Click="SelectSeat_Click"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</Window>
