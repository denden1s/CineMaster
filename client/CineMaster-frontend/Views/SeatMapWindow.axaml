<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CineMaster_frontend.Views.SeatMapWindow"
        Title="Выбор места"
        Width="640" Height="520">
  <DockPanel Margin="10">
    <StackPanel DockPanel.Dock="Top" Spacing="8">
      <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold"/>
      <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="Gray"/>

      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
        <Rectangle Width="14" Height="14" Fill="Red" Stroke="Black" StrokeThickness="1"/>
        <TextBlock Text="— занято" VerticalAlignment="Center"/>
        <Rectangle Width="14" Height="14" Fill="LightGray" Stroke="Black" StrokeThickness="1" Margin="10,0,0,0"/>
        <TextBlock Text="— свободно" VerticalAlignment="Center"/>
      </StackPanel>
    </StackPanel>

    <ScrollViewer DockPanel.Dock="Top" Height="340">
      <WrapPanel x:Name="SeatsPanel" ItemSpacing="4"/>
    </ScrollViewer>

    <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom" Margin="0,10,0,0" Foreground="Red"/>
  </DockPanel>
</Window>
